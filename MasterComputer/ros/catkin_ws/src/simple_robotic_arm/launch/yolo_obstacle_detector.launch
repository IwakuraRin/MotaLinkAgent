<?xml version="1.0"?>
<launch>
  <arg name="image_topic" default="/usb_cam/image_raw"/>
  <arg name="debug_image_topic" default="/obstacle_detector/debug"/>
  <arg name="model_path" default="$(find simple_robotic_arm)/models/obstacle_yolo11n_192.onnx"/>
  <arg name="input_size" default="192"/>
  <arg name="conf_thresh" default="0.05"/>
  <arg name="nms_thresh" default="0.45"/>
  <arg name="max_det" default="30"/>
  <arg name="output_width" default="320"/>
  <arg name="process_every_n" default="1"/>

  <node pkg="simple_robotic_arm" type="yolo_obstacle_detector" name="yolo_obstacle_detector" output="screen">
    <param name="image_topic" value="$(arg image_topic)"/>
    <param name="debug_image_topic" value="$(arg debug_image_topic)"/>
    <param name="model_path" value="$(arg model_path)"/>
    <param name="input_size" value="$(arg input_size)"/>
    <param name="conf_thresh" value="$(arg conf_thresh)"/>
    <param name="nms_thresh" value="$(arg nms_thresh)"/>
    <param name="max_det" value="$(arg max_det)"/>
    <param name="output_width" value="$(arg output_width)"/>
    <param name="process_every_n" value="$(arg process_every_n)"/>
  </node>
</launch>
